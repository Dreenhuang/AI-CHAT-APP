                      "fill": "#B04040",
                      "content": "反",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "600"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "Ea8Px",
                  "name": "chA2Bubble",
                  "width": 260,
                  "fill": "#FFFFFF",
                  "cornerRadius": 8,
                  "layout": "vertical",
                  "gap": 4,
                  "padding": 10,
                  "children": [
                    {
                      "type": "text",
                      "id": "f7xaP",
                      "name": "chA2Role",
                      "fill": "#FA5151",
                      "content": "反方-人文关怀派",
                      "fontFamily": "Inter",
                      "fontSize": 12,
                      "fontWeight": "500"
                    },
                    {
                      "type": "text",
                      "id": "PcEWB",
                      "name": "chA2Text",
                      "fill": "#1F1F1F",
                      "textGrowth": "fixed-width",
                      "width": 240,
                      "content": "这次不一样吧，AI不仅取代体力劳动，连脑力劳动也在蚕食。程序员、设计师、作家都在被影响。你说那些新工作在哪里呢？",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
            },
            {
              "type": "frame",
              "id": "vpGDm",
              "name": "Msg-User",
