# ============================================
# Git 忽略配置 - Admin Frontend
# ============================================

# 依赖目录
node_modules/
.pnp
.pnp.js

# 构建输出
dist/
dist-ssr/

# 环境变量文件（包含敏感信息）
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 编辑器配置
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 日志文件
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 操作系统文件
.DS_Store
Thumbs.db

# 临时文件
*.tmp
*.temp
.cache/
.parcel-cache/

# 测试覆盖率
coverage/
.nyc_output/

# TypeScript 缓存
*.tsbuildinfo

# Vite 缓存
.vite/
