                      "name": "chA1Role",
                      "fill": "#AFDD22",
                      "content": "正方-科技乐观派",
                      "fontFamily": "Inter",
                      "fontSize": 12,
                      "fontWeight": "500"
                    },
                    {
                      "type": "text",
                      "id": "jvWD9",
                      "name": "chA1Text",
                      "fill": "#1F1F1F",
                      "textGrowth": "fixed-width",
                      "width": 240,
                      "content": "我觉得AI不会取代人类，它更像是一个超级工具。你看历史上的工业革命，机器取代了体力劳动，但创造了更多新工作。AI也是一样的道理。",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
            },
            {
              "type": "frame",
              "id": "zq1U4",
              "name": "Msg-AI2",
              "width": "fill_container",
              "gap": 8,
              "children": [
