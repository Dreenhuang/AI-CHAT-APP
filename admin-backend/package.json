{
  "name": "admin-backend",
  "version": "2.0.0",
  "description": "PRD辩论APP - 管理员后端管理系统 (生产版 - 真实数据库+测试覆盖)",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.js",
    "start": "NODE_ENV=production bun run src/index.js",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev --name init",
    "db:push": "npx prisma db push",
    "db:seed": "node prisma/seed.js",
    "studio": "npx prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .js"
  },
  "keywords": ["admin", "backend", "fastify", "prisma", "jwt", "vitest"],
  "author": "GLM-5V-Turbo (AI Assistant)",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.3.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.0.1",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^8.57.0",
    "prisma": "6.3.0",
    "vitest": "^3.0.0"
  }
}