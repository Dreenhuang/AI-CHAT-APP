# AI Chat 生产环境配置
# 文件位置: server/.env.production
# 警告: 请勿将包含真实密钥的文件提交到 Git 仓库！
#       真实密钥应通过环境变量或密钥管理服务注入。

# 服务器端口
PORT=9461

# Supabase 数据库配置
SUPABASE_URL=https://jaduaifzmgvaotyqnjfe.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# MiniMax AI API (用于智能对话)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-M2.7

# DeepSeek API (备用)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# JWT Token 密钥 (生产环境请更换为强密码)
JWT_SECRET=aichat_production_secret_key_2026_change_me
JWT_EXPIRES_IN=7d

# 日志级别
LOG_LEVEL=info

# Node 环境
NODE_ENV=production
